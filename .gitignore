# ============================================================
# Gitignore for VOFF (Cyber Troopers Virtual On reverse engineering)
#
# Only original source code, scripts, and documentation are tracked.
# All data derived from the copyrighted V_ON.EXE / von.img is
# regenerated via the build pipeline (see Makefile).
# ============================================================

# Player-provided original artifact
von.img

# ============================================================
# Stage 1 output: extracted ISO contents (190 MB)
# Generated by: extract_von_img.py
# ============================================================
out_stage2/

# ============================================================
# Stage 2/4: Ghidra analysis artifacts
# Generated by: Ghidra headless scripts in ghidra_project/
# ============================================================
ghidra_project/VirtualOn.rep/
ghidra_project/VirtualOn.gpr

# ============================================================
# Stage 4/5: Decompiled output
# Generated by: ghidra_project/dump_*.py scripts
# ============================================================
out_decompile/src/
out_decompile/build/
out_decompile/voff_all.h
out_decompile/voff_stubs.h
out_decompile/voff_stubs.c
out_decompile/voff.c
out_decompile/voff.h
out_decompile/voff_processed.c
out_decompile/function_index.txt
out_decompile/call_graph.txt
out_decompile/ddraw_chain.c
out_decompile/ddraw_real_init.c
out_decompile/ddraw_functions.c
out_decompile/ddraw_function_map.txt
out_decompile/d3d_findings.txt
out_decompile/target_functions.c
out_decompile/.data.bin
out_decompile/.rdata.bin
out_decompile/.rsrc.bin

# ============================================================
# Build artifacts
# ============================================================
*.o
*.so
voff_sdl
voff.exe
voff.exe.so
data_init.bin
data_init.o
rdata_init.o

# ============================================================
# Runtime output
# ============================================================
voff.log
voff_sdl.log

# ============================================================
# Dependencies (installed separately)
# ============================================================
ghidra/
isos/
wine_prefix/
var/

# ============================================================
# Python
# ============================================================
__pycache__/
*.pyc
*.pyo

# ============================================================
# OS / Editor
# ============================================================
.DS_Store
Thumbs.db
*~
*.swp
*.swo
.vscode/
.idea/
BkUp.bin
*.png
out_decompile/dat_strings.h
out_decompile/interesting_strings.txt
